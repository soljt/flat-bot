# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend ─────────────────────────────────────────────────────────────────────
# Sign up at resend.com; verify your sending domain before use.
RESEND_API_KEY=re_...
RESEND_FROM=FlatBot <flatbot@yourdomain.com>

# ── Mailing list ───────────────────────────────────────────────────────────────
MAILING_LIST=soljthiessen@gmail.com,thiessen@privasphere.com,larshauptmann@outlook.com,giovio2000@gmail.com,stefanini.mat@gmail.com

# ── Platform toggles ───────────────────────────────────────────────────────────
ENABLE_FLATFOX=true
ENABLE_HOMEGATE=true

# ── Search criteria ────────────────────────────────────────────────────────────
MIN_ROOMS=5.0
MAX_RENT_CHF=6500
POSTCODE_PREFIX=80

# ── Poll schedule ──────────────────────────────────────────────────────────────
POLL_INTERVAL_MIN=15
POLL_JITTER_MIN=5

# ── Google Sheets (optional) ───────────────────────────────────────────────────
# See SHEETS_SETUP.md for how to generate these.
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=service-account.json

# ── FlareSolverr (Cloudflare bypass) ───────────────────────────────────────────
# FlareSolverr must be running before you start the bot.
# See README.md → "FlareSolverr setup" for Docker instructions.
FLARESOLVERR_URL=http://localhost:8191/v1
# How long FlareSolverr's browser has to solve the CF challenge (ms). Increase
# if you see warmup timeouts on a slow machine.
FLARESOLVERR_MAX_TIMEOUT_MS=60000

# ── Misc ───────────────────────────────────────────────────────────────────────
SEEN_STORE_PATH=seen.txt
